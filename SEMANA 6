import java.util.Scanner;

public class Main {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        ColaArreglo colaA = new ColaArreglo();
        ColaLista colaL = new ColaLista();
        ColaPrioridad colaP = new ColaPrioridad();

        int tipo, opcion;

        do {
            System.out.println("\n--- SELECCIONE TIPO DE COLA ---");
            System.out.println("1. Cola Arreglo Circular");
            System.out.println("2. Cola Lista Enlazada");
            System.out.println("3. Cola con Prioridad");
            System.out.println("4. Salir");
            System.out.print("Opcion: ");
            tipo = sc.nextInt();

            if (tipo == 4) break;

            do {
                System.out.println("\n1. Encolar");
                System.out.println("2. Desencolar");
                System.out.println("3. Volver");
                System.out.print("Opcion: ");
                opcion = sc.nextInt();

                switch (tipo) {

                    // arreglo
                    case 1:
                        if (opcion == 1) {
                            System.out.print("Valor: ");
                            int v = sc.nextInt();
                            colaA.enqueue(v);
                            colaA.mostrar();
                        } else if (opcion == 2) {
                            int x = colaA.dequeue();
                            if (x != -1) System.out.println("Se quitó: " + x);
                            colaA.mostrar();
                        }
                        break;

                    // lista
                    case 2:
                        if (opcion == 1) {
                            System.out.print("Valor: ");
                            int v = sc.nextInt();
                            colaL.enqueue(v);
                            colaL.mostrar();
                        } else if (opcion == 2) {
                            int x = colaL.dequeue();
                            if (x != -1) System.out.println("Se quitó: " + x);
                            colaL.mostrar();
                        }
                        break;

                    // prioridad
                    case 3:
                        if (opcion == 1) {
                            System.out.print("Valor: ");
                            int v = sc.nextInt();
                            System.out.print("Prioridad: ");
                            int p = sc.nextInt();
                            colaP.enqueue(v, p);
                            colaP.mostrar();
                        } else if (opcion == 2) {
                            int x = colaP.dequeue();
                            if (x != -1) System.out.println("Se quitó: " + x);
                            colaP.mostrar();
                        }
                        break;
                }

            } while (opcion != 3);

        } while (true);

    }
}

