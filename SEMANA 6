class ColaLista {
    Nodo frente = null;
    Nodo fin = null;

    // Agregar
    void enqueue(int x) {
        Nodo nuevo = new Nodo(x);

        if (frente == null) {
            frente = fin = nuevo;
        } else {
            fin.sig = nuevo;
            fin = nuevo;
        }
    }

    // Quitar
    int dequeue() {
        if (frente == null) {
            System.out.println("Cola vacía");
            return -1;
        }

        int valor = frente.dato;
        frente = frente.sig;

        if (frente == null) {
            fin = null;
        }

        return valor;
    }

    // Mostrar
    void mostrar() {
        if (frente == null) {
            System.out.println("Cola vacía");
            return;
        }

        System.out.print("Cola: ");
        Nodo aux = frente;

        while (aux != null) {
            System.out.print(aux.dato + " ");
            aux = aux.sig;
        }

        System.out.println();
    }
}

