class ColaArreglo {
    int[] cola = new int[5];
    int frente = 0;
    int fin = 0;
    int tamaño = 0;

    void enqueue(int x) {
        if (tamaño == 5) {
            System.out.println("Cola llena");
        } else {
            cola[fin] = x;
            fin = (fin + 1) % 5;
            tamaño++;
        }
    }

    int dequeue() {
        if (tamaño == 0) {
            System.out.println("Cola vacía");
            return -1;
        } else {
            int valor = cola[frente];
            frente = (frente + 1) % 5; 
            tamaño--;
            return valor;
        }
    }

    void mostrar() {
        if (tamaño == 0) {
            System.out.println("Cola vacía");
        } else {
            System.out.print("Cola: ");
            for (int i = 0; i < tamaño; i++) {
                int pos = (frente + i) % 5;
                System.out.print(cola[pos] + " ");
            }
            System.out.println();
        }
    }
}

