class ColaPrioridad {
    int[] valores = new int[5];
    int[] prioridad = new int[5];
    int n = 0;

    void enqueue(int v, int p) {
        if (n == valores.length) {
            System.out.println("Cola llena");
            return;
        }

        valores[n] = v;
        prioridad[n] = p;
        n++;
    }

    int dequeue() {
        if (n == 0) {
            System.out.println("Cola vacía");
            return -1;
        }

        int mayor = 0;
        for (int i = 1; i < n; i++) {
            if (prioridad[i] > prioridad[mayor]) {
                mayor = i;
            }
        }

        int valor = valores[mayor];

        // mover elementos
        for (int i = mayor; i < n - 1; i++) {
            valores[i] = valores[i + 1];
            prioridad[i] = prioridad[i + 1];
        }

        n--;
        return valor;
    }

    void mostrar() {
        if (n == 0) {
            System.out.println("Cola vacía");
            return;
        }

        System.out.print("Cola: ");
        for (int i = 0; i < n; i++) {
            System.out.print(valores[i] + "(p=" + prioridad[i] + ") ");
        }
        System.out.println();
    }
}

