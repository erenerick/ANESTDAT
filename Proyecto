public class Estudiante {
    private String codigo;
    private String nombre;
    private double[] notas;
    private int contadorNotas;

    public Estudiante(String codigo, String nombre) {
        this.codigo = codigo;
        this.nombre = nombre;
        this.notas = new double[5]; // máximo 5 notas
        this.contadorNotas = 0;
    }

    public void agregarNota(double nota) {
        if (contadorNotas < notas.length) {
            notas[contadorNotas] = nota;
            contadorNotas++;
        } else {
            System.out.println("Ya no se pueden agregar más notas");
        }
    }

    public double calcularPromedio() {
        double suma = 0;
        for (int i = 0; i < contadorNotas; i++) {
            suma += notas[i];
        }
        return contadorNotas > 0 ? suma / contadorNotas : 0;
    }

    public String getCodigo() {
        return codigo;
    }

    public void mostrar() {
        System.out.println(codigo + " - " + nombre + " | Promedio: " + calcularPromedio());
    }
}
