public class Estudiante {
    private String codigo;
    private String nombre;
    private double[][] notas; // matriz
    private int filas;  // evaluaciones usadas

    public Estudiante(String codigo, String nombre) {
        this.codigo = codigo;
        this.nombre = nombre;
        this.notas = new double[5][4]; // 5 filas (intentos), 4 columnas (evaluaciones)
        this.filas = 0;
    }

    public void agregarNotas(double[] nuevasNotas) {
        if (filas < notas.length) {
            for (int j = 0; j < nuevasNotas.length; j++) {
                notas[filas][j] = nuevasNotas[j];
            }
            filas++;
        } else {
            System.out.println("No se pueden agregar más registros");
        }
    }

    public double calcularPromedio() {
        double suma = 0;
        int total = 0;

        for (int i = 0; i < filas; i++) {
            for (int j = 0; j < notas[i].length; j++) {
                suma += notas[i][j];
                total++;
            }
        }

        return total > 0 ? suma / total : 0;
    }

    public void mostrar() {
        System.out.println(codigo + " - " + nombre);

        for (int i = 0; i < filas; i++) {
            for (int j = 0; j < notas[i].length; j++) {
                System.out.print(notas[i][j] + " ");
            }
            System.out.println();
        }

        System.out.println("Promedio: " + calcularPromedio());
    }

    public String getCodigo() {
        return codigo;
    }
}
