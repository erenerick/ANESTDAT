import java.util.Scanner;

public class Menu {
    private static Scanner sc = new Scanner(System.in);
    private static GestorEstudiantes gestor = new GestorEstudiantes();

    public static void mostrar() {
        int op;

        do {
            System.out.println("\n1. Registrar estudiante");
            System.out.println("2. Agregar nota");
            System.out.println("3. Mostrar estudiantes");
            System.out.println("4. Ranking");
            System.out.println("0. Salir");

            op = sc.nextInt();

            switch (op) {
                case 1:
                    System.out.print("Codigo: ");
                    String cod = sc.next();
                    System.out.print("Nombre: ");
                    String nom = sc.next();

                    gestor.agregarEstudiante(new Estudiante(cod, nom));
                    break;

                case 2:
                    System.out.print("Codigo: ");
                    cod = sc.next();
                    Estudiante e = gestor.buscar(cod);

                    if (e != null) {
                        System.out.print("Nota: ");
                        double nota = sc.nextDouble();
                        e.agregarNota(nota);
                    } else {
                        System.out.println("No existe");
                    }
                    break;

                case 3:
                    gestor.mostrarTodos();
                    break;

                case 4:
                    gestor.ranking();
                    break;
            }

        } while (op != 0);
    }
}
